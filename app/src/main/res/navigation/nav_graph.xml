<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment"> <fragment
    android:id="@+id/welcomeFragment"
    android:name="com.example.dermabsa.WelcomeFragment"
    android:label="Welcome"
    tools:layout="@layout/fragment_welcome">
    <action
        android:id="@+id/action_welcomeFragment_to_homeFragment"
        app:destination="@id/homeFragment" />
</fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.dermabsa.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_workspaceFragment"
            app:destination="@id/workspaceFragment" />
    </fragment>

    <fragment
        android:id="@+id/workspaceFragment"
        android:name="com.example.dermabsa.WorkspaceFragment"
        android:label="Workspace"
        tools:layout="@layout/fragment_workspace">
        <action
            android:id="@+id/action_workspaceFragment_to_scanFragment"
            app:destination="@id/scanFragment" />
    </fragment>

    <fragment
        android:id="@+id/scanFragment"
        android:name="com.example.dermabsa.ScanFragment"
        android:label="Scan"
        tools:layout="@layout/fragment_scan">
        <action
            android:id="@+id/action_scanFragment_to_cameraFragment"
            app:destination="@id/cameraFragment" />
        <action
            android:id="@+id/action_scanFragment_to_photoConfirmFragment"
            app:destination="@id/photoConfirmFragment" />
    </fragment>

    <fragment
        android:id="@+id/cameraFragment"
        android:name="com.example.dermabsa.CameraFragment"
        android:label="Camera"
        tools:layout="@layout/fragment_camera">
        <argument
            android:name="selectedRegion"
            app:argType="string" />
        <action
            android:id="@+id/action_cameraFragment_to_photoConfirmFragment"
            app:destination="@id/photoConfirmFragment" />
    </fragment>

    <fragment
        android:id="@+id/photoConfirmFragment"
        android:name="com.example.dermabsa.PhotoConfirmFragment"
        android:label="Confirm Photo"
        tools:layout="@layout/fragment_photo_confirm">
    </fragment>

</navigation>