    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="30dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintBottom_toBottomOf="@id/tv_header_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_header_home"
        app:layout_constraintVertical_bias="1.0"
        app:tint="@color/derma_teal" />

    <TextView
        android:id="@+id/tv_header_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:text="Seleziona Distretto"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/derma_text_dark"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subheader_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleziona la zona del corpo da analizzare"
        android:textColor="@color/derma_text_grey"
        app:layout_constraintStart_toStartOf="@id/tv_header_home"
        app:layout_constraintTop_toBottomOf="@id/tv_header_home" />

    <LinearLayout
        android:id="@+id/toggle_container"
        android:layout_width="237dp"
        android:layout_height="32dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_toggle_track"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.493"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subheader_home">

        <TextView
            android:id="@+id/tab_fronte"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_toggle_selected"
            android:gravity="center"
            android:text="Fronte"
            android:textColor="#000000"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_retro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_hotspot"
            android:gravity="center"
            android:text="Retro"
            android:textColor="#000000"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_zona_selezionata"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Zona selezionata: Nessuna"
        android:textColor="@color/derma_text_dark"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/btn_conferma"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_conferma"
        android:layout_width="182dp"
        android:layout_height="51dp"
        android:text="Conferma "
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        android:backgroundTint="@color/derma_teal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

